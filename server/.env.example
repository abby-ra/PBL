# ─────────────────────────────────────────────────────────────
# SAP Enterprise Decision Support AI — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# ── LLM Configuration ──────────────────────────────────────
# Choose provider: openai | anthropic | stub
# Use "stub" for development without API keys
LLM_PROVIDER=stub

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=1500

# Anthropic Claude (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── App Configuration ──────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_PORT=8000
SECRET_KEY=change-this-to-a-random-secret-string

# ── Database (replace with real DB in production) ──────────
# DATABASE_URL=postgresql://user:password@localhost:5432/sap_decision_ai

# ── SAP Integration (for production) ──────────────────────
# SAP_HANA_HOST=your-hana-host.hanacloud.ondemand.com
# SAP_HANA_PORT=443
# SAP_HANA_USER=your-user
# SAP_HANA_PASSWORD=your-password
# SAP_BTP_CLIENT_ID=your-client-id
# SAP_BTP_CLIENT_SECRET=your-client-secret
# SAP_BTP_TOKEN_URL=https://your-tenant.authentication.sap.hana.ondemand.com/oauth/token





#API

#REACT_APP_API_URL=http://localhost:8000/api
