# ═══════════════════════════════════════════════
# SAP Decision AI — .gitignore
# Place this file at: D:\Project\PBL\.gitignore
# (root of your entire project)
# ═══════════════════════════════════════════════


# ─────────────────────────────────────────────
# 🔐 SECRET / SENSITIVE — NEVER COMMIT THESE
# ─────────────────────────────────────────────
# Environment files (contain API keys, passwords)
.env
.env.local
.env.development
.env.production
.env.staging
*.env

# Keep the example template (safe to commit)
!.env.example


# ─────────────────────────────────────────────
# 📦 NODE / REACT (frontend)
# ─────────────────────────────────────────────
node_modules/
client/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# React build output
client/build/
client/dist/

# Cache
.npm
.eslintcache
.parcel-cache


# ─────────────────────────────────────────────
# 🐍 PYTHON (backend)
# ─────────────────────────────────────────────
# Virtual environments
venv/
env/
.venv/
server/venv/
server/env/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
*$py.class
*.pyc

# Python eggs / dist
*.egg
*.egg-info/
dist/
build/
.eggs/

# pytest
.pytest_cache/
.coverage
htmlcov/

# mypy
.mypy_cache/


# ─────────────────────────────────────────────
# 🗄️ DATABASES
# ─────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.sql


# ─────────────────────────────────────────────
# 📝 LOGS
# ─────────────────────────────────────────────
*.log
logs/
server/logs/
client/logs/


# ─────────────────────────────────────────────
# 💻 OS FILES
# ─────────────────────────────────────────────
# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Mac
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~


# ─────────────────────────────────────────────
# 🛠️ IDE / EDITOR
# ─────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.suo
*.user
*.sublime-project
*.sublime-workspace


# ─────────────────────────────────────────────
# 🔑 CERTIFICATES & KEYS
# ─────────────────────────────────────────────
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
secrets/
credentials/